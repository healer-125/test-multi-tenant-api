# -----------------------------------------------------------------------
data/*.db
data/*.db-shm
data/*.db-wal

# -----------------------------------------------------------------------
# Log files
# -----------------------------------------------------------------------
logs/*.log
*.log

# -----------------------------------------------------------------------
# Secrets / environment
# -----------------------------------------------------------------------
.env
.env.*
**/secrets.json
**/appsettings.*.json
# Re-include the committed settings files
!**/appsettings.json
!**/appsettings.Development.json

